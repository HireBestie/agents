{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hirebestie.com/schemas/market-radar/run-outcome.v1.json",
  "title": "MarketRadarRunOutcome",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "worldModel", "items", "droppedCount"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "worldModel": {
      "type": "object",
      "required": ["operatorSummary", "assumptions", "principles"],
      "properties": {
        "operatorSummary": { "type": "string", "minLength": 1 },
        "assumptions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "principles": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["observation", "impact", "recommendation"],
        "properties": {
          "observation": { "$ref": "observation.v1.json" },
          "impact": { "$ref": "impact-assessment.v1.json" },
          "recommendation": { "$ref": "recommendation.v1.json" }
        },
        "additionalProperties": false
      }
    },
    "droppedCount": { "type": "integer", "minimum": 0 },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
