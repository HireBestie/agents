{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hirebestie.com/schemas/market-radar/impact-assessment.v1.json",
  "title": "MarketRadarImpactAssessment",
  "type": "object",
  "required": [
    "assumption",
    "relation",
    "stance",
    "mechanism",
    "confidence",
    "affectedPrinciples",
    "evidence",
    "warrant"
  ],
  "properties": {
    "assumption": { "type": "string", "minLength": 1 },
    "relation": {
      "enum": ["supports", "contradicts", "activates", "inhibits", "context_only"]
    },
    "stance": {
      "enum": ["threat", "opportunity", "mixed", "watch_only"]
    },
    "mechanism": { "type": "string", "minLength": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "affectedPrinciples": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence": { "type": "string", "minLength": 1 },
    "warrant": { "type": "string", "minLength": 1 },
    "rebuttal": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
